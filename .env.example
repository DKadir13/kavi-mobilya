## Örnek environment dosyası (commit'lenebilir)
## Gerçek şifreleri buraya yazmayın; kendi ortamınıza göre düzenleyin.

# Yerel MongoDB (Docker / mongod)
MONGODB_URI=mongodb://adminKullanici:GucluSifre123@127.0.0.1:27017/kavi_mobilya?authSource=admin

MONGODB_DB_NAME=kavi_mobilya
JWT_SECRET=<strong-secret>

# İstemci tarafı API tabanı (canlıda örn. https://kavimobilya.com — sonuna /api otomatik eklenir)
# NEXT_PUBLIC_API_URL=https://kavimobilya.com

# Yüklenen dosyaların MongoDB’ye yazılacak tam URL öneki (varsayılan canlı site)
# PUBLIC_UPLOAD_BASE_URL=https://kavimobilya.com

# MONGODB_FORCE_IPV4=true
